@page "/case-edit/{id:int}"
@attribute [Authorize(Roles = "UPHCUser")]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using UPHC.SurveillanceDashboard.Data
@using UPHC.SurveillanceDashboard.Models
@using UPHC.SurveillanceDashboard.Services

@inject IDbContextFactory<AppDbContext> DbFactory
@inject NotificationService NotifService
@inject NavigationManager Navigation

<h3>Edit Case Status</h3>

@if (caseRecord == null)
{
    <p>Loading...</p>
}
else
{
    <div class="card p-4 shadow">

        <p><b>Patient:</b> @caseRecord.PatientName</p>
        <p><b>Disease:</b> @caseRecord.DiseaseName</p>
        <p><b>UPHC:</b> @(caseRecord.UPHC?.Name ?? "N/A")</p>

        <!-- ONLY STATUS EDITABLE -->
        <div class="mb-3">
            <label>Status</label>
            <!--enums values are unreadable so use @@bind-value-->
            <InputSelect @bind-Value="caseRecord.Status"      
                         TValue="CaseStatus"
                         class="form-control">

                <option value="Suspected">Suspected</option>
                <option value="Confirmed">Confirmed</option>
                <option value="Negative">Negative</option>

            </InputSelect>
        </div>

        <button class="btn btn-success"
                @onclick="HandleUpdate"
                disabled="@(originalStatus != null && caseRecord.Status == originalStatus)">
            Save
        </button>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="alert alert-info mt-3">@message</div>
        }

    </div>
}

@code {

    CaseStatus? originalStatus;
    [Parameter] public int id { get; set; }

    CaseRecord? caseRecord;
    string message = "";


    protected override async Task OnParametersSetAsync()
    {
        using var db = DbFactory.CreateDbContext();

        caseRecord = await db.CaseRecords
            .Include(c => c.UPHC)
            .FirstOrDefaultAsync(c => c.Id == id);

        if (caseRecord != null)
        {
            originalStatus = caseRecord.Status; 
        }
    }

    // protected override async Task OnParametersSetAsync()
