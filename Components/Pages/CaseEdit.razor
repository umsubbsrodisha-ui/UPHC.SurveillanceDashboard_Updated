    //         caseRecord.Status == CaseStatus.Negative)
    //     {
    //         caseRecord.LabConfirmedDate = DateTime.Now;
    //     }
    // }



    private async Task HandleUpdate()
    {
        using var db = DbFactory.CreateDbContext();

        var existing = await db.CaseRecords.FindAsync(caseRecord.Id);
        if (existing == null) return;

        //  ONLY UPDATE IF STATUS CHANGED
        if (existing.Status != caseRecord.Status)
        {
            existing.Status = caseRecord.Status;

            if (existing.Status == CaseStatus.Confirmed ||
                existing.Status == CaseStatus.Negative)
            {
                existing.LabConfirmedDate = DateTime.Now;
            }

            await db.SaveChangesAsync();

            //  SEND NOTIFICATION
            if (existing.Status == CaseStatus.Confirmed)
            {
                await NotifService.SendNotification(existing.Id, "Confirmed");
            }
            else if (existing.Status == CaseStatus.Negative)
            {
                await NotifService.SendNotification(existing.Id, "Negative");
            }

            //  DASHBOARD REFRESH
            await NotifService.NotifyDashboardUpdate();

            message = "Case updated successfully";
        }
        else
        {
            message = "No changes made";
        }

        Navigation.NavigateTo("/dashboard");
    }

