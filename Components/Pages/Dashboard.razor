@* @page "/dashboard"
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using UPHC.SurveillanceDashboard.Data
@using UPHC.SurveillanceDashboard.Models

@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@using Microsoft.AspNetCore.SignalR.Client

<div class="container-fluid dashboard-container">

    <h4 class="mb-4 fw-bold">🧬 Surveillance Dashboard</h4>

    <!-- 🔷 TOP SUMMARY -->
    <div class="row g-3 mb-4">

        <div class="col-12 col-md-4">
            <div class="glass-card gradient-blue text-white">
                <h6>Total Cases (14 days)</h6>
                <h1>@totalPatients</h1>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="glass-card gradient-red text-white">
                <h6>Confirmed Outbreaks</h6>
                <h1>@outbreaks.Count</h1>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="glass-card gradient-orange text-white">
                <h6>Suspected Clusters</h6>
                <h1>@suspectedClusters.Count</h1>
            </div>
        </div>

    </div>

    <!--Trend chart shows  current disease trends in city-->
    <div class="glass-card trend-card mb-4">
        <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap">
            <h5 class="mb-0">📈 Case Trend (Last 14 Days)</h5>
            <small class="text-muted">Confirmed vs Suspected</small>
        </div>

        <canvas id="trendChart"></canvas>
    </div>

    <!--Disease distribution pie chart-->
    <div class="glass-card mb-4">
        <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap">
            <h5 class="mb-0">🦠 Disease Distribution</h5>
            <small class="text-muted">Last 14 Days</small>
        </div>

        <canvas id="diseasePieChart"></canvas>
    </div>


    <!--UPHC wise case load-->
    <div class="glass-card mb-4">
        <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap">
            <h5 class="mb-0">🏥 UPHC Case Load</h5>
            <small class="text-muted">Facility-wise distribution</small>
        </div>

        <canvas id="uphcBarChart"></canvas>
    </div>




    <!--  OUTBREAKS -->
    <div class="glass-card mb-4">
        <h5 class="mb-3 text-danger">🚨 Confirmed Outbreaks</h5>

        @if (outbreaks.Count == 0)
        {
            <p>No outbreaks detected</p>
        }
        else
        {
            <div class="row g-3">
                @foreach (var o in outbreaks)
                {
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="mini-card red">
                            <strong>@o.DiseaseName</strong><br />
                            <small>@o.UPHCName</small><br />
                            <span>@o.Count cases</span>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!--  SUSPECTED -->
    <div class="glass-card mb-4">
        <h5 class="mb-3 text-warning">🟠 Suspected Clusters</h5>

        @if (suspectedClusters.Count == 0)
        {
            <p>No clusters</p>
        }
        else
        {
            <div class="row g-3">
                @foreach (var s in suspectedClusters)
                {
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="mini-card orange">
                            <strong>@s.DiseaseName</strong><br />
                            <small>@s.UPHCName</small><br />
                            <span>@s.Count cases</span>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!--  UPHC -->
    <div class="row g-3">
        @foreach (var u in uphcStats)
