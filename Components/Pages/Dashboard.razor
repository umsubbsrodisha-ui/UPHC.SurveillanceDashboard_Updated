            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                <div class="glass-card uphc-card"
                     @onclick="() => GoToUPHC(u.Id)">

                    <h6>@u.Name</h6>
                    <small>@u.Location</small>

                    <h2 class="mt-2">@u.TotalCases</h2>
                </div>
            </div>
        }
    </div>

</div>





