@*  
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using UPHC.SurveillanceDashboard.Data
@using UPHC.SurveillanceDashboard.Models
@using UPHC.SurveillanceDashboard.Services
@inject AuthenticationStateProvider AuthStateProvider
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Navigation



@page "/dashboard"
@attribute [Authorize]




<div class="container-fluid">

    <h5>UPHC Surveillance Dashboard</h5>
    <div class="row">
        <div class="col-md-12">
           
          
            <marquee>Dengue: 5 | Cholera: 2 | Malaria: 3</marquee>
        </div>
    </div>



    <div class="text-center p-4 mb-4 bg-dark text-white rounded">
        <h2>Last 14 Days Cases</h2>
        <h1 style="font-size: 6rem; font-weight: bold;">@totalPatients</h1>
    </div>



    <div class="card bg-danger text-white mb-4 p-4">
        <h2>🚨 Current Outbreaks</h2>

        @if (outbreaks.Count == 0)
        {
            <p>No outbreaks detected</p>
        }
        else
        {
            @foreach (var o in outbreaks)
            {
                <div>
                    <h4>@o.DiseaseName</h4>
                    <p>@o.UPHCName (@o.Count cases)</p>
                </div>
            }
        }
    </div>


    <div class="row">
        @foreach (var u in uphcStats)
        {
            <div class="col-md-3 mb-4">
                <div class="card shadow p-3 text-center uphc-card"
                     @onclick="() => GoToUPHC(u.Id)">

                    <h4>@u.Name</h4>
                    <p>@u.Location</p>

                    <h1 style="font-size: 3rem;">@u.TotalCases</h1>
                </div>
            </div>
        }
    </div>










</div>

@code {
    int totalPatients;
    List<OutbreakDto> outbreaks = new();
    List<UPHCStat> uphcStats = new();
    protected override async Task OnInitializedAsync()
    {
       
    
       
        using var db = DbFactory.CreateDbContext();

        DateTime fromDate = DateTime.Today.AddDays(-14);

        totalPatients = await db.CaseRecords
            .Where(c => c.CreatedDate >= fromDate)
            .CountAsync();


        outbreaks = await db.CaseRecords
              .Include(c => c.UPHC)
              .Where(c => c.CreatedDate >= fromDate)
              .GroupBy(c => new { c.DiseaseName, UPHCName = c.UPHC.Name })
              .Select(g => new OutbreakDto
              {
                  DiseaseName = g.Key.DiseaseName,
                  UPHCName = g.Key.UPHCName,
                  Count = g.Count()
              })
              .Where(x => x.Count >= 5)
              .ToListAsync();


        uphcStats = await db.UPHCs
.Select(u => new UPHCStat
{
  Id = u.Id,
  Name = u.Name,
  Location = u.Location,
  TotalCases = u.CaseRecords.Count()
})
.ToListAsync();
     
}


    void GoToUPHC(int id)
    {
        Navigation.NavigateTo($"/uphc/{id}");
    }
}




