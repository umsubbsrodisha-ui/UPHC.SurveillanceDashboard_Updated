</div>

@code {
    CaseRecord patient = new() { UPHCId = 1 };  // UPHC1 hardcoded for demo
    string message = "";
    bool success = false;

    private async Task HandleSave()
    {
        try
        {
            using var db = DbFactory.CreateDbContext();
            
            // Save patient record

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            patient.UserId = user.Identity?.Name ?? "DemoUser";


            patient.CreatedDate = DateTime.Now;
          //  patient.UserId = User.Identity?.Name ?? "DemoUser";
            db.Patients.Add(patient);
            await db.SaveChangesAsync();

            UPHC? uphc = await db.UPHCs.FindAsync(patient.UPHCId);
            string uphcName = uphc?.Name ?? "Unknown UPHC";

            // CRITICAL: TRIGGER NOTIFICATION IF COMMUNICABLE
            if (patient.IsCommunicable)
            {
                await NotifService.SendNotification(uphcName, patient.DiseaseName);
                message = $"Patient '{patient.Name}' saved. ALERT: {patient.DiseaseName} notification sent to Analyst!";
            }
            else
            {
                message = $"Patient '{patient.Name}' saved (non-communicable).";
            }

            success = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
            success = false;
        }
    }
} *@