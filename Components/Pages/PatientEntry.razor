            }

            // 🔥 Assign UPHC dynamically
            caseRecord.UPHCId = appUser.UPHCId.Value;

            caseRecord.UserId = appUser.Id;
            caseRecord.CreatedDate = DateTime.Now;
            caseRecord. DateReported = DateTime.Now;
            caseRecord.Status = CaseStatus.Suspected;

            // 💾 Save CaseRecord
            db.CaseRecords.Add(caseRecord);
            await db.SaveChangesAsync();

            // 🔴 Notification
            if (caseRecord.IsCommunicable)
            {
                await NotifService.SendNotification(caseRecord.Id, "NewCase");
                message = $"Case saved. ALERT sent for {caseRecord.DiseaseName}!";
            }
            else
            {
                message = $"Case saved (non-communicable).";
            }

            success = true;

            // 🔄 Reset form
            caseRecord = new CaseRecord();
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
            success = false;
        }
    }
}

 *@















@* @page "/patient-entry"
@attribute [Authorize(Roles = "UPHCUser")]
@inject NotificationService NotifService
@inject IDbContextFactory<AppDbContext> DbFactory
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.EntityFrameworkCore
@using UPHC.SurveillanceDashboard.Data
@using UPHC.SurveillanceDashboard.Services
@using UPHC.SurveillanceDashboard.Models
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.Identity;
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Patient Entry</PageTitle>

<div class="container mt-4">
    <EditForm Model="patient" OnValidSubmit="HandleSave" class="card p-4">
