@inherits LayoutComponentBase

@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.EntityFrameworkCore
@using UPHC.SurveillanceDashboard.Data
@using UPHC.SurveillanceDashboard.Models

@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject IDbContextFactory<AppDbContext> DbFactory

<!-- 🔷 TOP BAR -->
<div class="d-flex justify-content-between align-items-center px-3 py-2 shadow-sm bg-white">

    <!-- 🧬 TITLE -->
    <div class="fw-bold fs-4 text-primary">
        🧬 UMSU Surveillance
    </div>

    <!-- 👤 PROFILE SECTION -->
    <div class="position-relative">

        <!-- 👤 PROFILE IMAGE -->
        <img src="user.png"
             class="rounded-circle shadow-sm profile-avatar"
             @onclick="ToggleDropdown" />

        @if (isAnalyst && unreadCount > 0)
        {
            <!-- 🔔 NOTIFICATION COUNT -->
            <div class="notification-count">
                🔔 @unreadCount
            </div>

            <!-- 🔴 LIVE DOT -->
            <span class="notification-dot animate-blink"></span>
        }

        <!-- 🔽 DROPDOWN -->
        @if (showDropdown)
        {
            <div class="dropdown-menu show notification-dropdown">

                <!-- 👤 USER -->
                <div class="dropdown-item-text fw-bold text-primary">
                    @userName
                </div>

                <div class="dropdown-divider"></div>

                @if (isAnalyst)
                {
                    @if (notifications.Count == 0)
                    {
                        <div class="dropdown-item-text text-muted">
                            No notifications
                        </div>
                    }
                    else
                    {
                        @foreach (var n in notifications)
                        {
                            <a class="dropdown-item notification-item"
                                   @onclick="() => OpenCase(n)">

                                <div class="fw-semibold text-danger">
                                    @n.DiseaseName
                                </div>

                                <small class="text-muted">
                                    @(n.Facility?.FacilityName ?? "Unknown Facility")
                                </small>
                            </a>
                        }
                    }

                    <div class="dropdown-divider"></div>
                }

                <!-- 🚪 LOGOUT -->
                <button class="dropdown-item text-danger fw-semibold"
                        @onclick="Logout">
                    Logout
                </button>
            </div>
        }
    </div>
</div>

<!-- 🔷 MAIN LAYOUT -->
<div class="d-flex">

    <!-- 📚 LEFT NAV -->
    <NavMenu />

    <!-- 📄 PAGE CONTENT -->
    <div class="flex-fill p-3">
        @Body
    </div>
</div>

@code {

    string userName = "";
    bool showDropdown = false;

    bool isAnalyst = false;

    int unreadCount = 0;

    List<Notification> notifications = new();

    HubConnection? hubConnection;

    bool isBeeping = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();

        var user = authState.User;

        userName = user.Identity?.Name ?? "Guest";

        // ✅ Facility users
        bool isFacilityUser =
            user.IsInRole("UPHCUser") ||
            user.IsInRole("CHCUser") ||
            user.IsInRole("UHWCUser");

        // ✅ Analyst group
        isAnalyst = !isFacilityUser;

        if (isAnalyst)
        {
            if (hubConnection == null)
            {
                hubConnection = new HubConnectionBuilder()
                    .WithUrl(Navigation.ToAbsoluteUri("/notificationHub"))
                    .WithAutomaticReconnect()
                    .Build();

                // 🔔 RECEIVE NOTIFICATION
                hubConnection.On<int, NotificationType, string, string>(
                    "ReceiveNotification",
                    async (notificationId, type, disease, facility) =>
                    {
                        try
                        {
                            using var db = DbFactory.CreateDbContext();

                            var notification = await db.Notifications
                                .Include(n => n.Facility)
                                .FirstOrDefaultAsync(n => n.Id == notificationId);

                            if (notification != null)
                            {
                                bool isNew = false;

                                // ✅ Prevent duplicate notifications
                                if (!notifications.Any(n => n.Id == notification.Id))
                                {
                                    notifications.Insert(0, notification);

                                    unreadCount++;

                                    isNew = true;
                                }

                                if (isNew)
                                {
                                    // 🔊 START SOUND
                                    if (!isBeeping)
                                    {
                                        isBeeping = true;

                                        await JSRuntime.InvokeVoidAsync("startBeepLoop");
                                    }

                                    // 🚨 CONFIRMED ALERT
                                    if (type == NotificationType.ConfirmedPositive)
                                    {
                                        await JSRuntime.InvokeVoidAsync(
                                            "showToast",
                                            $"CONFIRMED: {disease} at {facility}"
                                        );
                                    }
                                }

                                // 🔄 UI REFRESH
                                await InvokeAsync(StateHasChanged);
                            }
                        }
                        catch (Exception ex)
                        {
                            Console.WriteLine($"Notification error: {ex.Message}");
                        }
                    });

                // 🔄 AUTO RECONNECT
                hubConnection.Reconnected += async (_) =>
                {
                    await hubConnection.SendAsync("JoinAnalystGroup");
                };

                await hubConnection.StartAsync();

                // ✅ JOIN GROUP
                await hubConnection.SendAsync("JoinAnalystGroup");
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection != null)
        {
            await hubConnection.DisposeAsync();
        }
    }

    // 👤 PROFILE CLICK
    async Task ToggleDropdown()
    {
        showDropdown = !showDropdown;

        // ✅ OPENING DROPDOWN
        if (showDropdown)
        {
            // 🔕 Reset unread count
            unreadCount = 0;

            // 🔇 Stop beep
            if (isBeeping)
            {
                isBeeping = false;

                await JSRuntime.InvokeVoidAsync("stopBeepLoop");
            }
        }
    }

    // 🚪 LOGOUT
    void Logout()
    {
        Navigation.NavigateTo("/logout", true);
    }

    // 📄 OPEN CASE
    void OpenCase(Notification n)
    {
        Navigation.NavigateTo($"/case-details/{n.CaseRecordId}");
    }
}











































