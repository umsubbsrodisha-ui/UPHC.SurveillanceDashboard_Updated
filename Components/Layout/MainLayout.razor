        var user = authState.User;

        userName = user.Identity?.Name ?? "Guest";
        isAnalyst = user.IsInRole("Analyst") || user.IsInRole("Admin");

        if (isAnalyst)
        {
            hubConnection = new HubConnectionBuilder()
                .WithUrl("/notificationHub")
                .WithAutomaticReconnect()
                .Build();

            // ✅ Receive notification by ID
            hubConnection.On<int>("ReceiveNotification", async (notificationId) =>
            {
                try
                {
                    using var db = DbFactory.CreateDbContext();

                    var notification = await db.Notifications
                        .Include(n => n.UPHC)
                        .FirstOrDefaultAsync(n => n.Id == notificationId);

                    if (notification != null)
                    {
                        unreadCount++;

                        // ✅ Prevent duplicates (IMPORTANT)
                        if (!notifications.Any(n => n.Id == notification.Id))
                        {
                            notifications.Insert(0, notification);
                        }

                        // 🔊 Start beep
                        if (!isBeeping)
                        {
                            isBeeping = true;
                            await JSRuntime.InvokeVoidAsync("startBeepLoop");
                        }

                        await InvokeAsync(StateHasChanged);
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Notification error: {ex.Message}");
                }
            });

            // ✅ Handle reconnect (VERY IMPORTANT)
            hubConnection.Reconnected += async (connectionId) =>
            {
                await hubConnection.SendAsync("JoinAnalystGroup");
            };

            await hubConnection.StartAsync();
            await hubConnection.SendAsync("JoinAnalystGroup");
        }
    }

    public async ValueTask DisposeAsync() => await hubConnection.DisposeAsync();

async Task ToggleDropdown()
    {
        showDropdown = !showDropdown;

        if (showDropdown)
        {
            unreadCount = 0;

            if (isBeeping)
            {
                isBeeping = false;
                await JSRuntime.InvokeVoidAsync("stopBeepLoop");
            }
        }
    }

    void Logout()
    {
        Navigation.NavigateTo("/logout", true);
    }

    void OpenCase(Notification n)
    {
        Navigation.NavigateTo($"/case-details/{n.Id}");
    }

   
