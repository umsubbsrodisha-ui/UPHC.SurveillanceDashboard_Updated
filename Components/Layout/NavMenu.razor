@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider

<div class="nav flex-column p-2 bg-light" style="width:220px; min-height:100vh;">

    <a href="/dashboard" class="nav-link">Dashboard</a>

    @if (isFacilityUser)
    {
        <a href="/patiententry" class="nav-link">Patient Entry</a>
    }

    @if (isAnalystGroup)
    {
        <a href="/records" class="nav-link">Records</a>
        <a href="/uphc-list" class="nav-link">UPHC List</a>
    }

</div>

@code {
    bool isAnalystGroup = false;
    bool isFacilityUser = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        // ❌ Facility users
        isFacilityUser =
            user.IsInRole("UPHCUser") ||
            user.IsInRole("CHCUser") ||
            user.IsInRole("UHWCUser");

        // ✅ Analyst group = everyone except facility users
        isAnalystGroup = !isFacilityUser;
    }
}





































