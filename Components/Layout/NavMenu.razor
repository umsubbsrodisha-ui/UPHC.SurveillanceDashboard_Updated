@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider

<div class="nav flex-column p-2 bg-light" style="width:220px;">

    <a href="/dashboard" class="nav-link">Dashboard</a>

    @if (isUPHCUser)
    {
        <a href="/patiententry" class="nav-link">Patient Entry</a>
    }

    @if (isAnalyst)
    {
        <a href="/records" class="nav-link">Records</a>
        <a href="/uphc-list" class="nav-link">UPHC List</a>
    }

</div>

@code {
    bool isAnalyst = false;
    bool isUPHCUser = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        isAnalyst = user.IsInRole("Analyst") || user.IsInRole("Admin");
        isUPHCUser = user.IsInRole("UPHCUser");
    }
} 
